# moonstone — example env
# Copy to .env or inject via SOPS (see nix/module.nix)

# ---- Required ---------------------------------------------------------------
PDS_HOSTNAME=pds.example.com
PDS_JWT_SECRET=                                    # openssl rand --hex 16
PDS_ADMIN_PASSWORD=                                # openssl rand --hex 16
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX=         # openssl ecparam -name secp256k1 -genkey -noout -outform DER | tail -c +8 | head -c 32 | xxd -p -c 32

# ---- Identity ----------------------------------------------------------------
# did:plc registry — plc.directory is the canonical ATProto PLC registry.
# Override to point at a self-hosted PLC directory if desired.
PDS_PLC_URL=https://plc.directory
# PDS_SERVICE_DID=did:web:pds.example.com          # defaults to did:web:<hostname>

# ---- Service -----------------------------------------------------------------
PDS_PORT=2583
PDS_DATA_DIRECTORY=/srv/bluesky-pds
# PDS_VERSION=0.1.0
# PDS_DEV_MODE=false

# ---- Blobstore ---------------------------------------------------------------
# PDS_BLOBSTORE_DISK_LOCATION=/srv/bluesky-pds/blobs   # defaults to DATA_DIRECTORY/blobs
# PDS_BLOB_UPLOAD_LIMIT=5242880                          # 5 MiB

# ---- Handles -----------------------------------------------------------------
# PDS_SERVICE_HANDLE_DOMAINS=.pds.example.com           # defaults to .<hostname>

# ---- Email (optional) --------------------------------------------------------
# Both must be set, or neither.
# PDS_EMAIL_SMTP_URL=smtps://user:pass@smtp.example.com
# PDS_EMAIL_FROM_ADDRESS=noreply@example.com

# ---- Crawlers (OPT-IN ONLY) --------------------------------------------------
# Not set = PDS will NOT announce itself to any relay.
# Uncomment to participate in the wider ATProto network via bsky.network:
# PDS_CRAWLERS=https://bsky.network
