# moonstone — example env (copy to .env or inject via SOPS)
# Required
PDS_HOSTNAME=pds.example.com
PDS_JWT_SECRET=                         # openssl rand --hex 16
PDS_ADMIN_PASSWORD=                     # openssl rand --hex 16
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX=  # see atproto docs

# Optional — defaults shown
PDS_PORT=2583
PDS_DATA_DIRECTORY=/srv/bluesky-pds
PDS_PLC_URL=https://plc.directory
PDS_CRAWLERS=https://bsky.network
# PDS_SERVICE_HANDLE_DOMAINS=.pds.example.com
# PDS_SERVICE_DID=did:web:pds.example.com
# PDS_VERSION=0.1.0
# PDS_DEV_MODE=false
