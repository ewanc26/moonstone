{
  "name": "@ewanc26/moonstone-server",
  "version": "0.1.0",
  "description": "Personal ATProto PDS server — standalone, no @atproto/pds dependency",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@atproto/common": "^0.4.3",
    "@atproto/crypto": "^0.4.2",
    "@atproto/identity": "^0.4.3",
    "@atproto/syntax": "^0.3.1",
    "@atproto/xrpc-server": "^0.7.0",
    "@did-plc/lib": "^0.0.12",
    "@ewanc26/moonstone-config": "workspace:*",
    "@ewanc26/moonstone-native": "workspace:*",
    "@hapi/address": "^6.0.0",
    "better-sqlite3": "^9.6.0",
    "disposable-email-domains-js": "^1.0.4",
    "express": "^4.21.2",
    "http-terminator": "^3.2.0",
    "jose": "^5.9.6",
    "nodemailer": "^6.9.16",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "uint8arrays": "^5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.17",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
