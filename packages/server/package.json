{
  "name": "@ewanc26/moonstone-server",
  "version": "0.1.0",
  "description": "Personal ATProto PDS server — standalone, no @atproto/pds dependency",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@atproto/common": "^0.4.3",
    "@atproto/crypto": "^0.4.2",
    "@atproto/identity": "^0.4.3",
    "@atproto/lexicon": "^0.4.4",
    "@atproto/repo": "^0.5.0",
    "@atproto/syntax": "^0.3.1",
    "@atproto/xrpc-server": "^0.7.0",
    "@did-plc/lib": "^0.0.4",
    "@ewanc26/moonstone-config": "workspace:*",
    "@ewanc26/moonstone-native": "workspace:*",
    "@hapi/address": "^5.1.1",
    "better-sqlite3": "^9.6.0",
    "bytes": "^3.1.2",
    "disposable-email-domains-js": "^1.0.4",
    "express": "^4.21.2",
    "file-type": "^19.6.0",
    "http-terminator": "^3.2.0",
    "jose": "^5.9.6",
    "multiformats": "^13.3.1",
    "nodemailer": "^6.9.16",
    "p-queue": "^8.1.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "typed-emitter": "^2.1.0",
    "uint8arrays": "^5.1.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bytes": "^3.1.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/ws": "^8.5.14",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
