{
  "name": "@ewanc26/moonstone-server",
  "version": "0.1.0",
  "description": "Personal ATProto PDS server — no Bluesky infra defaults",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@atproto/pds": "^0.4.208",
    "@atproto/syntax": "^0.3.1",
    "@ewanc26/moonstone-config": "workspace:*",
    "@ewanc26/moonstone-native": "workspace:*",
    "express": "^4.21.2",
    "http-terminator": "^3.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
